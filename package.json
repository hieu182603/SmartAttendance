{
  "name": "smartattendance",
  "private": true,
  "version": "0.1.0",
  "engines": {
    "node": "20.x"
  },
  "packageManager": "pnpm@10.12.1",
  "scripts": {
    "postinstall": "pnpm --filter @smartattendance/shared build",
    "build:shared": "pnpm --filter @smartattendance/shared build",
    "dev:backend": "pnpm --filter @smartattendance/backend dev",
    "dev:web": "pnpm --filter @smartattendance/web dev",
    "dev:ai": "cd packages/ai-service && DEV_MODE=true python run.py",
    "build": "pnpm --filter @smartattendance/web build",
    "build:all": "pnpm -r build",
    "lint": "pnpm -r --parallel lint",
    "test": "pnpm -r --parallel test"
  }
}
