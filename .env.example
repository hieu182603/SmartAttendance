# ============================================================
# SmartAttendance — ROOT environment file for docker-compose
# Copy to `.env` (same folder as docker-compose.yml) and fill in real values.
# docker compose interpolates ${VAR} below from this file.
# NEVER commit the real .env — it is git-ignored.
# ============================================================

# --- Database (MongoDB Atlas) ---
MONGO_URI=<YOUR_MONGODB_URI>

# --- Security (generate each with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))") ---
JWT_SECRET=<YOUR_JWT_SECRET>
REFRESH_TOKEN_SECRET=<YOUR_DIFFERENT_REFRESH_SECRET>

# --- Frontend / CORS ---
# Public web origin (Vercel domain), no trailing slash
FRONTEND_URL=https://www.your-domain.com
# Extra allowed origins, comma-separated (e.g. Vercel preview URLs). Optional.
ALLOWED_ORIGINS=

# --- AI service shared secret (must match ai-service API_KEY) ---
AI_SERVICE_API_KEY=<YOUR_AI_SERVICE_API_KEY>
# CORS allowlist consumed by the Python ai-service container
ALLOWED_ORIGINS_AI=http://backend:4000,https://www.your-domain.com
# Google Gemini key used by ai-service RAG
GOOGLE_API_KEY=<YOUR_GOOGLE_API_KEY>

# --- Cloudinary (avatar / face image storage) ---
CLOUDINARY_CLOUD_NAME=<YOUR_CLOUDINARY_CLOUD_NAME>
CLOUDINARY_API_KEY=<YOUR_CLOUDINARY_API_KEY>
CLOUDINARY_API_SECRET=<YOUR_CLOUDINARY_API_SECRET>

# --- Email (OTP fallback) ---
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=<YOUR_SMTP_USER>
EMAIL_PASS=<YOUR_SMTP_APP_PASSWORD>

# --- Sensitive field encryption (bank account at rest) ---
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BANK_ACCOUNT_ENCRYPTION_KEY=<YOUR_32_BYTE_HEX_KEY>

# --- PayOS (billing / payment) ---
PAYOS_CLIENT_ID=<YOUR_PAYOS_CLIENT_ID>
PAYOS_API_KEY=<YOUR_PAYOS_API_KEY>
PAYOS_CHECKSUM_KEY=<YOUR_PAYOS_CHECKSUM_KEY>

# --- Observability (optional) ---
LOG_LEVEL=info

# --- Google Analytics Data API ---
GA_PROPERTY_ID=<YOUR_GA_PROPERTY_ID>
# Option A: path to service account JSON file (mount into container via docker-compose volumes)
GA_SERVICE_ACCOUNT_KEY_PATH=<YOUR_GA_SERVICE_ACCOUNT_KEY_PATH>
# Option B: base64-encoded service account JSON (preferred for containerised/serverless deployments)
# Generate with: base64 -w0 your-service-account.json
GA_SERVICE_ACCOUNT_KEY=
