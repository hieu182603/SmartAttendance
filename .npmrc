# Required for Expo / React Native Metro bundler to resolve workspace packages.
# Without this, Metro cannot find hoisted deps in the root node_modules.
shamefully-hoist=true

# Use hoisted linker (vs symlink) — more compatible with Metro + Vercel build cache.
node-linker=hoisted

# Don't auto-install peer deps silently — make conflicts explicit.
auto-install-peers=true

# Keep lockfile pinned to exact versions for reproducible CI builds.
save-exact=false
