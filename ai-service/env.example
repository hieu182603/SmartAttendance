# Server Configuration
PORT=8001
HOST=0.0.0.0
LOG_LEVEL=INFO

# AI Model Configuration
MODEL_NAME=buffalo_l
DETECTION_THRESHOLD=0.5
VERIFICATION_THRESHOLD=0.6

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:4000,http://localhost:5173

# API Authentication
# This key is used by consumers of the AI service via `X-API-Key` header.
# Example: X-API-Key: super-secure-ai-key-123
API_KEY=your_ai_service_api_key_here

# JWT Configuration (should match backend JWT_SECRET for shared authentication)
JWT_SECRET=
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# Face Registration Configuration
# Default values are 4 images (thẳng, trên, trái, phải)
MIN_REGISTRATION_IMAGES=4
MAX_REGISTRATION_IMAGES=4

# Liveness requirement for /api/face/register (default: false)
# If true, requests must include liveness_* fields and pass verification.
REQUIRE_LIVENESS_FOR_REGISTRATION=false

# RAG Configuration (MongoDB Atlas Vector Search)
MONGODB_ATLAS_CLUSTER_URI=
GOOGLE_API_KEY=your_google_api_key_here
VECTOR_SEARCH_INDEX_NAME=vector_index
RAG_COLLECTION_NAME=documents
CONVERSATIONS_COLLECTION_NAME=rag_conversations

# Chatbot Configuration
CHATBOT_MAX_CONVERSATIONS=50
CHATBOT_MAX_MESSAGES=50
CHATBOT_TEMPERATURE=0.7
CHATBOT_MAX_TOKENS=2000