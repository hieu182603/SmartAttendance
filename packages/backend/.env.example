# ============================================================
# SmartAttendance Backend — Environment Variables
# Copy this file to .env and fill in your actual values.
# NEVER commit the real .env file.
# ============================================================

# --- Database ---
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/smartattendance?retryWrites=true&w=majority

# --- Server ---
PORT=4000
NODE_ENV=production

# --- JWT (generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=<min-64-char-random-hex>
REFRESH_TOKEN_SECRET=<min-64-char-random-hex>
JWT_EXPIRES_IN=7d

# --- Email (Gmail App Password recommended) ---
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=<gmail-app-password>

# --- Cloudinary ---
CLOUDINARY_CLOUD_NAME=<your-cloud-name>
CLOUDINARY_API_KEY=<your-api-key>
CLOUDINARY_API_SECRET=<your-api-secret>

# --- Frontend (for CORS and Socket.io) ---
FRONTEND_URL=https://your-domain.com

# --- AI Service ---
AI_SERVICE_URL=http://localhost:8001
AI_SERVICE_API_KEY=<shared-secret-with-ai-service>
AI_SERVICE_TIMEOUT=30000
ENABLE_FACE_RECOGNITION=true
FACE_VERIFICATION_THRESHOLD=0.6
REQUIRE_FACE_VERIFICATION=true

# --- Gemini AI (for RAG chatbot) ---
GEMINI_API_KEY=<your-gemini-api-key>
CHATBOT_MODEL=gemini-1.5-pro
CHATBOT_MAX_TOKENS=2000
CHATBOT_TEMPERATURE=0.7

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- IP Blocklist (optional, comma-separated) ---
# BLOCKED_IPS=1.2.3.4,5.6.7.8

# --- PayOS (billing / payment) ---
PAYOS_CLIENT_ID=<your-payos-client-id>
PAYOS_API_KEY=<your-payos-api-key>
PAYOS_CHECKSUM_KEY=<your-payos-checksum-key>

# --- Swagger docs (production only) ---
# Set a strong password. Leave unset to disable /api/docs entirely in production.
SWAGGER_PASSWORD=<strong-password>
