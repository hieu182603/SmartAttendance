# ============================================================
# SmartAttendance AI Service — Environment Variables
# Copy this file to .env and fill in your actual values.
# NEVER commit the real .env file.
# ============================================================

# --- Server ---
PORT=8001
HOST=0.0.0.0
LOG_LEVEL=INFO

# --- Face Recognition Model ---
MODEL_NAME=buffalo_sc
DETECTION_THRESHOLD=0.3
VERIFICATION_THRESHOLD=0.65

# --- CORS (comma-separated list of allowed origins) ---
ALLOWED_ORIGINS=https://your-domain.com,https://api.your-domain.com

# --- Authentication ---
# Must match AI_SERVICE_API_KEY in backend/.env
API_KEY=<strong-shared-secret>
# Must match JWT_SECRET in backend/.env (for internal token validation)
JWT_SECRET=<same-jwt-secret-as-backend>
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
# Set to true ONLY for local dev when API_KEY is unset. NEVER in production.
ALLOW_INSECURE_AUTH=false

# --- Face Registration ---
MIN_REGISTRATION_IMAGES=4
MAX_REGISTRATION_IMAGES=4

# --- RAG / MongoDB Atlas Vector Search ---
MONGODB_ATLAS_CLUSTER_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/smartattendance?retryWrites=true&w=majority
GOOGLE_API_KEY=<your-gemini-api-key>
RAG_COLLECTION_NAME=rag_documents
VECTOR_SEARCH_INDEX_NAME=vector_index_rag
CONVERSATIONS_COLLECTION_NAME=rag_conversations

# --- Chatbot ---
CHATBOT_MAX_CONVERSATIONS=50
CHATBOT_MAX_MESSAGES=50
CHATBOT_TEMPERATURE=0.7
CHATBOT_MAX_TOKENS=2000

# --- Anti-Spoofing ---
ANTI_SPOOFING_ENABLED=true
ANTI_SPOOFING_METHOD=sfas
ANTI_SPOOFING_THRESHOLD=0.5
REQUIRE_LIVENESS_FOR_REGISTRATION=false

# --- RAG Cache ---
RAG_CACHE_ENABLED=true
RAG_CACHE_TTL=300
RAG_CACHE_MAXSIZE=1000
RAG_PARALLEL_QUERIES=true

# --- AI Token Pricing (USD per 1M tokens) ---
AI_PRICE_GEMINI_FLASH_INPUT_PER_1M=0.075
AI_PRICE_GEMINI_FLASH_OUTPUT_PER_1M=0.30
AI_PRICE_EMBEDDING_PER_1M=0.025
AI_USD_TO_VND=25500
