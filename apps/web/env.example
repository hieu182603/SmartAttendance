# API & Socket.io Server URL (required)
# Example: https://api.smartattendance.com or http://localhost:4000
VITE_API_URL=

# Chatbot Configuration (optional)
# Enable/disable chatbot feature (default: true)
VITE_CHATBOT_ENABLED=true

# RAG Service URL for AI chatbot (optional)
# The RAG FastAPI router is mounted under `/api/rag`, while the frontend calls `/rag/...`.
# A trailing `/api` is added automatically if missing, so BOTH of these work:
#   http://localhost:8001        (the `/api` is appended for you)
#   http://localhost:8001/api    (used as-is, not duplicated)
# Fly example: http://<host>:8080
VITE_RAG_SERVICE_URL=http://localhost:8001

# Face Registration Configuration (optional)
# Minimum number of images required for face registration (default: 4)
VITE_MIN_REGISTRATION_IMAGES=4

# Maximum number of images allowed for face registration (default: 4)
VITE_MAX_REGISTRATION_IMAGES=4

# NOTE: VITE_AI_SERVICE_API_KEY is NOT used in frontend code.
# All AI service requests go through api.ts which attaches the user's JWT token.
# Set AI_SERVICE_API_KEY only in backend/.env — the backend proxies auth to the AI service.