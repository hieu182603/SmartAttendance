# ============================================================
# SmartAttendance Frontend — Environment Variables
# Copy this file to .env and fill in your actual values.
# NEVER commit the real .env file.
# ============================================================

# Backend API URL (no trailing slash)
VITE_API_URL=https://api.your-domain.com

# RAG chatbot service URL — must include /api prefix
VITE_RAG_SERVICE_URL=https://api.your-domain.com/api

# Chatbot feature toggle
VITE_CHATBOT_ENABLED=true

# Face registration image count
VITE_MIN_REGISTRATION_IMAGES=4
VITE_MAX_REGISTRATION_IMAGES=10

# NOTE: VITE_AI_SERVICE_API_KEY is NOT used in frontend code.
# All AI service requests are authenticated via the user's JWT token (handled by api.ts).
# The AI service API key is only needed on the backend (backend/.env: AI_SERVICE_API_KEY).
