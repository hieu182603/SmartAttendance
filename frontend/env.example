# API & Socket.io Server URL (required)
# Example: https://api.smartattendance.com or http://localhost:4000
VITE_API_URL=

# Chatbot Configuration (optional)
# Enable/disable chatbot feature (default: true)
VITE_CHATBOT_ENABLED=true

# RAG Service URL for AI chatbot (optional)
# IMPORTANT: the RAG FastAPI router is mounted under `/api/rag`, while the frontend calls `/rag/...`.
# Therefore this base URL MUST include `/api` so `/rag/...` resolves to `/api/rag/...`.
# Local example: http://localhost:8001/api
# Fly example:   http://<host>:8080/api
VITE_RAG_SERVICE_URL=http://localhost:8001/api

# Face Registration Configuration (optional)
# Minimum number of images required for face registration (default: 4)
VITE_MIN_REGISTRATION_IMAGES=4

# Maximum number of images allowed for face registration (default: 4)
VITE_MAX_REGISTRATION_IMAGES=4

# AI Service Authentication (optional)
# If your backend proxies AI service, this can be left empty.
# If frontend calls AI service directly, set the same value as AI_SERVICE_API_KEY / API_KEY in backend/ai-service.
VITE_AI_SERVICE_API_KEY=your_ai_service_api_key_here